{
  "name": "saathicare",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "webapp",
    "mobile_app",
    "server"
  ],
  "scripts": {
    "install:all": "npm install --include=dev --workspaces",
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace webapp\"",
    "build": "npm run build --workspace webapp && npm run seed --workspace server",
    "seed": "npm run seed --workspace server",
    "start": "node server/src/index.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  }
}
